pipeline {
    agent any

    stages {

        stage('Unit Tests - Backend') {
            agent {
                docker {
                    image 'golang:1.21'
                    reuseNode true
                    args '--network=host'
                }
            }

            environment {
                GOCACHE = "${WORKSPACE}/.cache/go-build"
                GOMODCACHE = "${WORKSPACE}/.cache/go-mod"
            }

            steps {
                dir('bugtracker-backend') {
                    sh '''
                        set -e

                        mkdir -p $GOCACHE $GOMODCACHE

                        go mod download

                        # Install tool per conversione JSON → JUnit
                        go install github.com/jstemmer/go-junit-report/v2@latest
                        export PATH=$PATH:$(go env GOPATH)/bin

                        # Test Go in formato compatibile CI
                        go test ./... -v 2>&1 | go-junit-report > test-results.xml
                    '''
                }
            }

            post {
                always {
                    junit 'bugtracker-backend/test-results.xml'
                    archiveArtifacts artifacts: 'bugtracker-backend/test-results.xml', fingerprint: true
                }
            }
        }


        stage('Unit Tests - Frontend') {
            agent {
                docker {
                    image 'node:20'
                    reuseNode true
                    args '--network=host'
                }
            }

            steps {
                dir('bugtracker-frontend') {
                    sh '''
                        set -e

                        node -v
                        npm -v

                        npm ci

                        npm test -- --ci
                    '''
                }
            }

            post {
                always {
                    junit 'bugtracker-frontend/junit.xml'
                    archiveArtifacts artifacts: 'bugtracker-frontend/junit.xml', fingerprint: true
                }
            }
        }
    }
}