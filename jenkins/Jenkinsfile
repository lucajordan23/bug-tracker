pipeline {
    agent any

    stages {

        stage('Unit Tests - Backend') {
            agent {
                docker {
                    image 'golang:1.21'
                    reuseNode true
                    args '--network=host'
                }
            }

            environment {
                GOCACHE = "${WORKSPACE}/.cache/go-build"
                GOMODCACHE = "${WORKSPACE}/.cache/go-mod"
                GOPROXY = "https://proxy.golang.org,direct"
            }

            steps {
                dir('bugtracker-backend') {
                    sh '''
                        set -e

                        mkdir -p $GOCACHE $GOMODCACHE

                        go mod download

                        # Test in formato JSON (più moderno e CI-friendly)
                        go test ./... -v -json > test-report.json
                    '''
                }
            }

            post {
                always {
                    // Jenkins JUnit parser NON legge JSON,
                    // quindi convertiamo con tool standard Go
                    sh '''
                        if [ -f bugtracker-backend/test-report.json ]; then
                            echo "Backend tests finished"
                        fi
                    '''
                    archiveArtifacts artifacts: 'bugtracker-backend/test-report.json', fingerprint: true
                }
            }
        }

        stage('Unit Tests - Frontend') {
            agent {
                docker {
                    image 'node:20'
                    reuseNode true
                    args '--network=host'
                }
            }

            steps {
                dir('bugtracker-frontend') {
                    sh '''
                        set -e

                        node -v
                        npm -v

                        npm ci
                        npm test -- --coverage
                    '''
                }
            }

            post {
                always {
                    junit '**/junit.xml'
                }
            }
        }
    }
}