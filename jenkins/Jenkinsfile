pipeline {
    agent any

    stages {
        stage('Unit Tests - Backend') {
            agent {
                docker {
                    image 'golang:1.21'
                    reuseNode true
                    args '--network=host'
                }
            }

            environment {
                GOCACHE = "${WORKSPACE}/.cache/go-build"
                GOMODCACHE = "${WORKSPACE}/.cache/go-mod"
                GOPROXY = "https://proxy.golang.org,direct"
            }

            steps {
                dir('bugtracker-backend') {
                    sh '''
                        mkdir -p $GOCACHE $GOMODCACHE
                        go mod download
                        go test -v ./...
                    '''
                }
            }
        }
    

        stage('Unit Tests - Frontend') {
            agent {
                docker {
                    image 'node:20'
                    reuseNode true
                    args '--network=host'
                }
             }
            steps {
                dir('bugtracker-frontend') {
                    sh '''
                    node -v
                    npm -v

                    npm ci --verbose

                    ls -la
                    ls -la node_modules/.bin || true

                    npm test
                    '''
                }
            } 
            post {
                always{
                    junit 'backtracker-frontend/test-results.xml'
                }
            }  
        }   
    }   
}   