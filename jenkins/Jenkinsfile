pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Debug') {
            steps {
                sh '''
                    echo "WORKSPACE:"
                    pwd
                    ls -la
                '''
            }
        }

        stage('Build Backend') {
            steps {
                sh '''
                    docker build -t backend .
                '''
            }
        }

        stage('Unit Tests') {
            parallel {

                stage('Backend Tests') {
                    agent any
                    steps {
                        sh '''
                            docker run --rm \
                                -v $WORKSPACE:/app \
                                -w /app/bugtracker-backend \
                                golang:1.21 \
                                sh -c "go test ./..."
                        '''
                    }
                }

                stage('Frontend Tests') {
                    agent any
                    steps {
                        sh '''
                            docker run --rm \
                                -v $WORKSPACE:/app \
                                -w /app/bugtracker-frontend \
                                node:20 \
                                sh -c "npm ci && npm test"
                        '''
                    }
                }
            }
        }

        stage('Launch Application') {
            steps {
                sh '''
                    docker compose up -d --build
                '''
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}